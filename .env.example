# =============================================================================
# Migration Orchestration Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API (FastAPI)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# -----------------------------------------------------------------------------
# IBM Cloud (Target: VPC)
# -----------------------------------------------------------------------------
IBM_CLOUD_API_KEY=your-ibm-cloud-api-key
IBM_CLOUD_REGION=us-south
IBM_CLOUD_RESOURCE_GROUP=your-resource-group
IBM_VPC_ID=your-vpc-id

# -----------------------------------------------------------------------------
# IBM Classic (Source Adapter)
# -----------------------------------------------------------------------------
IBM_CLASSIC_USERNAME=your-classic-username
IBM_CLASSIC_API_KEY=your-classic-api-key

# -----------------------------------------------------------------------------
# VMware (Source Adapter)
# -----------------------------------------------------------------------------
VMWARE_HOST=vcenter.example.com
VMWARE_PORT=443
VMWARE_USERNAME=administrator@vsphere.local
VMWARE_PASSWORD=your-vmware-password
VMWARE_DATACENTER=your-datacenter
VMWARE_VERIFY_SSL=true

# -----------------------------------------------------------------------------
# Hyper-V (Source Adapter)
# -----------------------------------------------------------------------------
HYPERV_HOST=hyperv.example.com
HYPERV_USERNAME=your-hyperv-username
HYPERV_PASSWORD=your-hyperv-password

# -----------------------------------------------------------------------------
# Bare Metal (Source Adapter)
# -----------------------------------------------------------------------------
BAREMETAL_IPMI_HOST=ipmi.example.com
BAREMETAL_IPMI_USERNAME=your-ipmi-username
BAREMETAL_IPMI_PASSWORD=your-ipmi-password

# -----------------------------------------------------------------------------
# Temporal Workflow Engine
# -----------------------------------------------------------------------------
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=migration
TEMPORAL_TASK_QUEUE=migration-tasks

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
TERRAFORM_BINARY_PATH=/usr/local/bin/terraform
TERRAFORM_WORKING_DIR=/tmp/terraform-output
TERRAFORM_STATE_BACKEND=local

# -----------------------------------------------------------------------------
# Kubernetes Migration
# -----------------------------------------------------------------------------
KUBECONFIG_PATH=~/.kube/config
K8S_SOURCE_CONTEXT=source-cluster-context
K8S_TARGET_CONTEXT=target-cluster-context
VELERO_BACKUP_BUCKET=your-velero-backup-bucket

# -----------------------------------------------------------------------------
# Object Storage (for backups / state)
# -----------------------------------------------------------------------------
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_API_KEY=your-cos-api-key
COS_INSTANCE_CRN=your-cos-instance-crn
COS_BUCKET=migration-state

# -----------------------------------------------------------------------------
# Data Migration (rsync)
# -----------------------------------------------------------------------------
RSYNC_SSH_KEY_PATH=~/.ssh/id_rsa
RSYNC_BANDWIDTH_LIMIT=0

# -----------------------------------------------------------------------------
# Database (if applicable)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/migration_db

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_FORMAT=json
ENABLE_METRICS=false
METRICS_PORT=9090
