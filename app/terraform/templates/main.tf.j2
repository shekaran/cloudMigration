terraform {
  required_providers {
    ibm = {
      source  = "IBM-Cloud/ibm"
      version = "~> 1.60"
    }
  }
  required_version = ">= 1.5.0"
}

provider "ibm" {
  region = "{{ vpc.region }}"
}

# -----------------------------------------------------------------------------
# VPC
# -----------------------------------------------------------------------------
resource "ibm_is_vpc" "{{ vpc.name | replace('-', '_') }}" {
  name           = "{{ vpc.name }}"
  resource_group = "{{ vpc.resource_group }}"
  address_prefix_management = "manual"
}

resource "ibm_is_vpc_address_prefix" "{{ vpc.name | replace('-', '_') }}_prefix" {
  name = "{{ vpc.name }}-prefix"
  vpc  = ibm_is_vpc.{{ vpc.name | replace('-', '_') }}.id
  zone = "{{ vpc.region }}-1"
  cidr = "{{ vpc.address_prefix_cidr }}"
}

{% for subnet in subnets %}
# -----------------------------------------------------------------------------
# Subnet: {{ subnet.name }}
# Source: {{ subnet.source_network_name }}
# -----------------------------------------------------------------------------
resource "ibm_is_subnet" "{{ subnet.name | replace('-', '_') }}" {
  name            = "{{ subnet.name }}"
  vpc             = ibm_is_vpc.{{ vpc.name | replace('-', '_') }}.id
  zone            = "{{ subnet.zone }}"
  ipv4_cidr_block = "{{ subnet.ipv4_cidr_block }}"
  {% if subnet.public_gateway %}
  public_gateway  = ibm_is_public_gateway.{{ subnet.name | replace('-', '_') }}_gw.id
  {% endif %}

  depends_on = [ibm_is_vpc_address_prefix.{{ vpc.name | replace('-', '_') }}_prefix]
}

{% if subnet.public_gateway %}
resource "ibm_is_public_gateway" "{{ subnet.name | replace('-', '_') }}_gw" {
  name = "{{ subnet.name }}-gw"
  vpc  = ibm_is_vpc.{{ vpc.name | replace('-', '_') }}.id
  zone = "{{ subnet.zone }}"
}

{% endif %}
{% endfor %}
{% for sg in security_groups %}
# -----------------------------------------------------------------------------
# Security Group: {{ sg.name }}
# -----------------------------------------------------------------------------
resource "ibm_is_security_group" "{{ sg.name | replace('-', '_') }}" {
  name = "{{ sg.name }}"
  vpc  = ibm_is_vpc.{{ vpc.name | replace('-', '_') }}.id
}

{% for rule in sg.rules %}
resource "ibm_is_security_group_rule" "{{ sg.name | replace('-', '_') }}_rule_{{ loop.index }}" {
  group     = ibm_is_security_group.{{ sg.name | replace('-', '_') }}.id
  direction = "{{ rule.direction }}"
  {% if rule.protocol != "all" %}
  {{ rule.protocol }} {
    {% if rule.port_min is not none %}
    port_min = {{ rule.port_min }}
    {% endif %}
    {% if rule.port_max is not none %}
    port_max = {{ rule.port_max }}
    {% endif %}
  }
  {% endif %}
  remote = "{{ rule.remote_cidr }}"
}

{% endfor %}
{% endfor %}
{% for instance in instances %}
# -----------------------------------------------------------------------------
# Instance: {{ instance.name }}
# Source VM: {{ instance.source_vm_name }}
# Profile: {{ instance.profile }}
# -----------------------------------------------------------------------------
resource "ibm_is_instance" "{{ instance.name | replace('-', '_') }}" {
  name    = "{{ instance.name }}"
  vpc     = ibm_is_vpc.{{ vpc.name | replace('-', '_') }}.id
  zone    = "{{ instance.zone }}"
  profile = "{{ instance.profile }}"
  image   = "{{ instance.image }}"

  primary_network_interface {
    subnet          = ibm_is_subnet.{{ instance.subnet_name | replace('-', '_') }}.id
    {% if instance.security_group_names %}
    security_groups = [
      {% for sg_name in instance.security_group_names %}
      ibm_is_security_group.{{ sg_name | replace('-', '_') }}.id,
      {% endfor %}
    ]
    {% endif %}
  }

  boot_volume {
    size = {{ instance.boot_volume_gb }}
  }

  {% for vol_gb in instance.data_volumes %}
  volume_attachments {
    name   = "{{ instance.name }}-data-{{ loop.index }}"
    volume = ibm_is_volume.{{ instance.name | replace('-', '_') }}_data_{{ loop.index }}.id
  }

  {% endfor %}
}

{% for vol_gb in instance.data_volumes %}
resource "ibm_is_volume" "{{ instance.name | replace('-', '_') }}_data_{{ loop.index }}" {
  name     = "{{ instance.name }}-data-{{ loop.index }}"
  profile  = "general-purpose"
  zone     = "{{ instance.zone }}"
  capacity = {{ vol_gb }}
}

{% endfor %}
{% endfor %}
# -----------------------------------------------------------------------------
# Outputs
# -----------------------------------------------------------------------------
output "vpc_id" {
  value = ibm_is_vpc.{{ vpc.name | replace('-', '_') }}.id
}

{% for subnet in subnets %}
output "subnet_{{ subnet.name | replace('-', '_') }}_id" {
  value = ibm_is_subnet.{{ subnet.name | replace('-', '_') }}.id
}

{% endfor %}
{% for instance in instances %}
output "instance_{{ instance.name | replace('-', '_') }}_id" {
  value = ibm_is_instance.{{ instance.name | replace('-', '_') }}.id
}

{% endfor %}
